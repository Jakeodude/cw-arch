# Python bytecode caches
# Note: this repo intentionally tracks specific cpython-312 .pyc files
# (see commit history). gitignore does not untrack already-tracked files,
# so those remain versioned; only new/untracked __pycache__ entries from
# other Python versions or local toolruns are ignored.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local settings
.claude/

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
